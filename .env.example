# ============================================================
# Team Architect Assistant — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# ---- Azure OpenAI ----
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# ---- Entra ID (backend token validation) ----
ENTRA_TENANT_ID=<tenant-guid>
ENTRA_API_CLIENT_ID=<backend-app-registration-client-id>
ENTRA_API_AUDIENCE=api://<backend-app-registration-client-id>

# ---- KB Git repo ----
KB_REPO_URL=https://dev.azure.com/<org>/<project>/_git/team-kb
KB_REPO_BRANCH=main
KB_REPO_LOCAL_PATH=./kb_data
KB_REPO_AUTH_METHOD=pat
KB_REPO_PAT=<personal-access-token>
KB_SYNC_INTERVAL_SECONDS=900
KB_REPO_LOCAL_ONLY=true

# ---- Database ----
DATABASE_URL=sqlite:///./app.db

# ---- App ----
APP_ENV=dev
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=http://localhost:5173

# ---- Auth bypass (dev only — rejected if APP_ENV != dev) ----
DEV_AUTH_BYPASS=true

# ---- Tool config ----
TOOL_SHELL_ENABLED=true
TOOL_AZ_CLI_ENABLED=true
TOOL_MS_DOCS_ENABLED=true
TOOL_APPROVAL_TIMEOUT_SECONDS=600

# ---- Rate limiting ----
CHAT_RATE_LIMIT_PER_MINUTE=30

# ---- Backup (prod only) ----
BACKUP_ENABLED=false
BACKUP_AZURE_STORAGE_CONNECTION_STRING=
BACKUP_CONTAINER_NAME=sqlite-backups
BACKUP_INTERVAL_SECONDS=86400
