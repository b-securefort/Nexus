# ── Required: Azure OpenAI ──────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_CONTEXT_WINDOW_TOKENS=128000
AZURE_OPENAI_DEPLOYMENT_High=gpt-5.4
AZURE_OPENAI_API_VERSION_High=2025-04-01-preview
AZURE_OPENAI_CONTEXT_WINDOW_TOKENS_High=400000
# Total context window of the chat deployment, in tokens. Used as the
# denominator for the frontend context-usage indicator. Update alongside
# AZURE_OPENAI_DEPLOYMENT when the underlying model changes.


# ── Required: Database ──────────────────────────────────────
DATABASE_URL=sqlite:///./app.db

# ── Knowledge Base ──────────────────────────────────────────
KB_REPO_LOCAL_PATH=./kb_data
KB_REPO_LOCAL_ONLY=true
# KB_REPO_URL=https://dev.azure.com/org/project/_git/kb-repo
# KB_REPO_BRANCH=main
# KB_REPO_PAT=your-pat-here

# ── ADO wiki ingestion (multi-source) ───────────────────────
# JSON list of {label, org, project, wiki} records. Empty (default) = disabled.
# `label` is a stable identity slug (regex ^[a-z][a-z0-9-]{1,39}$); convention
# is slug(project) with optional disambiguator. PAT scope uses KB_REPO_PAT
# (org-level Wiki(read)). See DESIGN.md §6 "ADO wiki source labels".
# INGEST_ADO_WIKI_SOURCES=[{"label":"platform","org":"https://dev.azure.com/myorg","project":"Platform","wiki":"Platform.wiki"}]

# ── Dev mode ────────────────────────────────────────────────
APP_ENV=dev
DEV_AUTH_BYPASS=true

# ── Entra ID (production only) ──────────────────────────────
ENTRA_TENANT_ID=placeholder
ENTRA_API_CLIENT_ID=placeholder
ENTRA_API_AUDIENCE=api://placeholder

# ── Tool toggles (all true by default) ─────────────────────
TOOL_SHELL_ENABLED=true
TOOL_AZ_CLI_ENABLED=true
TOOL_MS_DOCS_ENABLED=true
TOOL_AZ_COST_ENABLED=true
TOOL_AZ_MONITOR_ENABLED=true
TOOL_AZ_REST_ENABLED=true
TOOL_GENERATE_FILE_ENABLED=true
TOOL_AZ_DEVOPS_ENABLED=true
TOOL_AZ_POLICY_ENABLED=true
TOOL_AZ_ADVISOR_ENABLED=true
TOOL_NETWORK_TEST_ENABLED=true
TOOL_DIAGRAM_GEN_ENABLED=true
TOOL_WEB_FETCH_ENABLED=true

# ── Per-user weekly spend cap (DESIGN.md §5 2026-06-14) ─────
# Two-stage rollout: ENABLED shows the "credits left" indicator + /api/usage/me
# (soft); ENFORCED additionally BLOCKS over-cap turns (hard). Both must be true
# to block. Caps are configured in USD here; the UI displays credits (×100,
# 1 credit = $0.01), so 20.0 USD shows as 2000 credits.
USAGE_CAP_ENABLED=true
USAGE_CAP_ENFORCED=false
# Default weekly cap (USD) for users with no per-user override. Set/clear
# per-user caps at /admin/users (architect-gated).
USAGE_WEEKLY_CAP_USD_DEFAULT=20.0
# Real Azure OpenAI prices, USD per 1,000,000 tokens, keyed by EXACT deployment
# name (must match AZURE_OPENAI_DEPLOYMENT / _HIGH above). Single line, no breaks.
# Layers over built-in placeholder defaults — set this so credit counts reflect
# actual cost. `cached` is the cheaper rate for the cached subset of prompt tokens.
# USAGE_PRICE_TABLE_JSON={"gpt-5.4":{"prompt":2.50,"cached":0.25,"completion":10.00},"gpt-4o-mini":{"prompt":0.15,"cached":0.075,"completion":0.60}}
# Optional per-Entra-role weekly caps (USD), JSON {role: usd}. A per-user value
# wins; otherwise the highest matching role cap; otherwise the default above.
# USAGE_ROLE_CAPS_JSON={"architect":50,"engineer":25}
# Ledger retention for reporting (the weekly cap math only looks back 2 weeks).
USAGE_LEDGER_RETENTION_DAYS=90
USAGE_LEDGER_PRUNE_INTERVAL_SECONDS=86400

# Forensic audit log of approval-gated tool executions (tool_executions table).
# Own retention window, independent of the usage ledger — raise it to keep the
# trail longer (incidents surface late). The prune sweeper is the only deleter.
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_LOG_PRUNE_INTERVAL_SECONDS=86400

# ── Misc ────────────────────────────────────────────────────
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:5174
TOOL_APPROVAL_TIMEOUT_SECONDS=600
CHAT_RATE_LIMIT_PER_MINUTE=30
BACKUP_ENABLED=false
